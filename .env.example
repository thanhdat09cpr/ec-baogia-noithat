# === Mẫu biến môi trường cho deploy VPS (copy thành .env, điền giá trị thật) ===
# .env KHÔNG commit (đã có trong .gitignore).

# --- Postgres ---
POSTGRES_USER=baogia
POSTGRES_PASSWORD=doi-mat-khau-manh-o-day
POSTGRES_DB=baogia
# App nối tới service 'db' trong compose (driver psycopg v3):
DATABASE_URL=postgresql+psycopg://baogia:doi-mat-khau-manh-o-day@db:5432/baogia

# --- AI qua OpenRouter (key chung máy chủ; client cũng có thể tự nhập trên web bản test) ---
OPENROUTER_API_KEY=sk-or-...
# Model mặc định (slug OpenRouter): anthropic/claude-opus-4.8 hoặc openai/gpt-5.5
TAKEOFF_MODEL=anthropic/claude-opus-4.8

# --- App ---
# SECRET_KEY: chuỗi ngẫu nhiên >=32 bytes. Tạo: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai
# Tỷ giá quy đổi ước tính chi phí token (VND/USD)
USD_VND_RATE=25000

# --- HTTPS qua Traefik CÓ SẴN trên VPS (không chạy proxy riêng) ---
# Traefik route theo DOMAIN + tự xin cert Let's Encrypt (certresolver 'letsencrypt').
# - Subdomain Hostinger (mặc định, KHÔNG cần trỏ DNS, cert tự động):
DOMAIN=baogia.srv1741374.hstgr.cloud
# - Hoặc domain riêng: đổi thành baogia.eurostyle.com.vn VÀ trỏ A record về IP VPS trước.

# --- (Phase 3 — khi bật lại auth Google) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# ADMIN_EMAILS=hoang.dang@eurostyle.com.vn,nguoi-hai@eurostyle.com.vn
