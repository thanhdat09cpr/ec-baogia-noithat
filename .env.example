# === Mẫu biến môi trường cho deploy VPS (copy thành .env, điền giá trị thật) ===
# .env KHÔNG commit (đã có trong .gitignore).

# --- Postgres ---
POSTGRES_USER=baogia
POSTGRES_PASSWORD=doi-mat-khau-manh-o-day
POSTGRES_DB=baogia
# App nối tới service 'db' trong compose (driver psycopg v3):
DATABASE_URL=postgresql+psycopg://baogia:doi-mat-khau-manh-o-day@db:5432/baogia

# --- AI (key chung của công ty) ---
ANTHROPIC_API_KEY=sk-ant-...
TAKEOFF_MODEL=claude-opus-4-8

# --- App ---
# SECRET_KEY: chuỗi ngẫu nhiên >=32 bytes. Tạo: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai
# Tỷ giá quy đổi ước tính chi phí token (VND/USD)
USD_VND_RATE=25000

# --- Caddy (HTTPS) ---
DOMAIN=baogia.eurostyle.com.vn
ACME_EMAIL=admin@eurostyle.com.vn

# --- (Phase 3 — khi bật lại auth Google) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# ADMIN_EMAILS=hoang.dang@eurostyle.com.vn,nguoi-hai@eurostyle.com.vn
